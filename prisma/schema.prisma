generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Post {
  id        String   @id @default(uuid())
  name      String   @default("Untitled")
  imageUrl  String   @map("image_url") // thumbnail key (images/thumb-{same-key})
  caption   String
  createdAt DateTime @default(now()) @map("created_at")
  images    Image[]

  @@map("posts")
}

model Image {
  id        String   @id @default(uuid())
  imageUrl  String   @map("image_url") // full-size key (images/{timestamp}-{random}.{ext})
  postId    String   @map("post_id")
  sortOrder Int      @default(0) @map("sort_order")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("images")
}
