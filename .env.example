# Profile Configuration
NEXT_PUBLIC_PROFILE_NAME=Your Name
NEXT_PUBLIC_PROFILE_HANDLE=yourhandle
NEXT_PUBLIC_AVATAR_URL=https://example.com/avatar.jpg

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your bcrypt hash here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=lifeframe
R2_PUBLIC_URL=https://your-subdomain.r2.dev

# Database - Connect via Supabase connection pooling
DATABASE_URL=postgresql://postgres.user:password@host:6543/dbname?pgbouncer=true

# Direct connection (for migrations)
DIRECT_URL=postgresql://postgres.user:password@host:5432/dbname